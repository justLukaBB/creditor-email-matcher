# Application Settings
ENVIRONMENT=development
LOG_LEVEL=INFO
API_KEY=your_api_key_here

# Database (using psycopg3 driver)
DATABASE_URL=postgresql+psycopg://creditor_user:creditor_pass@localhost:5432/creditor_matcher

# LLM Configuration
LLM_PROVIDER=claude

# Anthropic Claude (Recommended)
ANTHROPIC_API_KEY=your-anthropic-api-key-here
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# OpenAI (Alternative)
# OPENAI_API_KEY=sk-your-openai-api-key-here
# OPENAI_MODEL=gpt-4o

# Zendesk
ZENDESK_SUBDOMAIN=rascuric
ZENDESK_EMAIL=thomas@ra-scuric.de
ZENDESK_API_TOKEN=your-zendesk-api-token-here

# Security
WEBHOOK_SECRET=your-random-secure-webhook-secret-here

# Matching Engine Configuration (optional - defaults in config.py)
MATCH_THRESHOLD_HIGH=0.80
MATCH_THRESHOLD_MEDIUM=0.60
MATCH_LOOKBACK_DAYS=60
